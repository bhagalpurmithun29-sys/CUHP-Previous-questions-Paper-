# ---------------------------------------------------------
# CUHP Question Bank - Environment Configuration Template
# DO NOT COMMIT SECRETS TO SOURCE CONTROL
# ---------------------------------------------------------

# Environment
NODE_ENV=development
PORT=5000

# Database Credentials
MONGO_URI=mongodb://localhost:27017/cuhp

# JWT Secrets
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# OAuth Credentials
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP Credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Cloud Storage Credentials
STORAGE_BUCKET_NAME=cuhp-assets-dev
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key

# AI Provider Keys
AI_PROVIDER_API_KEY=your_openai_or_anthropic_key

# Push Notification Keys
PUSH_NOTIFICATION_VAPID_PUBLIC=your_vapid_public_key
PUSH_NOTIFICATION_VAPID_PRIVATE=your_vapid_private_key
